# Config (ข้อมูล credentials - ห้ามขึ้น git)
# ใช้ config/* (ไม่ใช่ config/) เพื่อให้บรรทัด ! ด้านล่างยกเว้นไฟล์เดียวได้จริง —
# git ไม่ไล่เข้าไปเช็ค negation ในไดเรกทอรีที่ถูก exclude ทั้งโฟลเดอร์
config/*
# ยกเว้น template ตัวอย่าง — ไม่มี credentials จริง และ auto_bot.spec ต้องใช้ตอน build .exe
!config/bot_config.example.yaml

# Images ที่ capture ไว้ (เฉพาะเครื่อง)
triggers/
elements/

# Data files
data/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# Logs / screenshots
logs/
*.log
screenshots/

# PyInstaller / Build
build/
dist/

# Internal concept/analysis notes (เก็บเฉพาะเครื่อง ไม่ขึ้น repo สาธารณะ)
concepts/

# AI self-heal runtime state (screenshot ของจอจริง — ไม่ควรขึ้น git)
ai_heal/
ai_heal_test_before.png
